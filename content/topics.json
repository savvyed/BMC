          "steps": [
            {
              "text": "Close the MyChart app.",
              "mediaType": "",
              "mediaUrl": ""
            },
            {
              "text": "Go to your phone's Settings.",
              "mediaType": "",
              "mediaUrl": ""
            },
            {
              "text": "Find MyChart in your list of apps.",
              "mediaType": "",
              "mediaUrl": ""
            },
            {
              "text": "Tap \"Permissions.\"",
              "mediaType": "",
              "mediaUrl": ""
            },
            {
              "text": "Make sure the Camera toggle is turned On.",
              "mediaType": "",
              "mediaUrl": ""
            },
            {
              "text": "Re-open MyChart and try again.",
              "mediaType": "",
              "mediaUrl": ""
